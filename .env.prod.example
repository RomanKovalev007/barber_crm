# ── Domain ──────────────────────────────────────────────────────────
DOMAIN=api.example.com

# ── Docker images ──────────────────────────────────────────────────
IMAGE_PREFIX=ghcr.io/romankovalev007/barber_crm
IMAGE_TAG=latest

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── ClickHouse ─────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Grafana ────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
